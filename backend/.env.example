# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Redis Configuration (Optional for Phase 1, Required for Phase 3)
REDIS_URL=your_redis_cloud_url

# Pinecone Configuration (Optional for Phase 1, Required for Phase 3)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX_NAME=genesis-memory

# Google Gemini AI (Required for Phase 1)
GEMINI_API_KEY=your_gemini_api_key

# ElevenLabs Voice (Optional for Phase 1, Required for Phase 4)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
SECRET_KEY=your-super-secret-jwt-key

# CORS
FRONTEND_URL=http://localhost:5173

# Credential Encryption (Required for Phase 2)
CREDENTIAL_ENCRYPTION_KEY=your_generated_encryption_key_here